# =============================================
# RabbitMQ PJI510 - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
#
# NUNCA versione o arquivo .env com senhas reais.
# =============================================

# Credencial do administrador (usado no primeiro boot)
RABBITMQ_USER=admin
RABBITMQ_PASS=TROCAR_ANTES_DO_DEPLOY

# Credenciais dos producers/consumers (configurar via Management UI ou rabbitmqctl)
# SENSOR_PRODUCER_USER=sensor_producer
# SENSOR_PRODUCER_PASS=TROCAR_ANTES_DO_DEPLOY
# ALERTA_CONSUMER_USER=alerta_consumer
# ALERTA_CONSUMER_PASS=TROCAR_ANTES_DO_DEPLOY
